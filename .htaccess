# Ayurveda Quiz — Apache Config

Options -Indexes
ServerSignature Off

# ── Force HTTPS (uncomment on production) ────────────────────
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── Gzip Compression ──────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# ── Browser Caching ───────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
</IfModule>

# ── Security Headers ──────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options nosniff
  Header always set X-Frame-Options SAMEORIGIN
  Header always set X-XSS-Protection "1; mode=block"
  # Block access to PHP files in uploads
  Header set Content-Security-Policy "default-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.quilljs.com https://fonts.googleapis.com https://api.whatsapp.com https://twitter.com data:; img-src 'self' data: https:;"
</IfModule>

# ── Protect uploads folder from PHP execution ─────────────────
<FilesMatch "\.(php|phtml|php3|php4|php5|pl|py|jsp|asp|sh|cgi)$">
  Order Deny,Allow
  Deny from all
</FilesMatch>

# ── Protect config.php ────────────────────────────────────────
<Files "config.php">
  Order Deny,Allow
  Deny from all
</Files>

# ── URL Routing ───────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Block direct config access
  RewriteRule ^api/config\.php$ - [F,L]

  # Skip real files and directories
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Category pages: /category/bams/ → pages/category.html?slug=bams
  RewriteRule ^category/([^/]+)/?$ /pages/category.html?slug=$1 [L,QSA]

  # Blog post URLs: /some-post-slug/ → post.php?slug=some-post-slug
  RewriteRule ^([a-z0-9][a-z0-9\-]+[a-z0-9])/?$ /post.php?slug=$1 [L,QSA]
</IfModule>
